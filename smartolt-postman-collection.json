{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "SmartOLT API",
    "description": "Complete SmartOLT API Collection for managing OLTs and ONUs. Includes authentication via X-Token header.\n\n## Authentication\n- Header: `X-Token: {{api_key}}`\n- Content-Type: `application/x-www-form-urlencoded`\n\n## Base URL\n`https://{{subdomain}}.smartolt.com/api`\n\n## Rate Limits\n- `get_all_onus_details`: Max 3 calls/hour\n- All \"Get All\" endpoints are rate-limited. Cache data instead of polling.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "System",
      "description": "System-level endpoints for OLT management",
      "item": [
        {
          "name": "Get OLTs",
          "description": "List all OLTs registered in SmartOLT. Returns names, IP addresses, telnet/SNMP ports, and unique IDs for each OLT.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Token", "value": "{{api_key}}", "type": "text" }
            ],
            "url": {
              "raw": "https://{{subdomain}}.smartolt.com/api/system/get_olts",
              "protocol": "https",
              "host": ["{{subdomain}}.smartolt.com"],
              "path": ["api", "system", "get_olts"]
            },
            "description": "Lists all OLTs with their details (name, IP, ports, ID)."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\"status\": true, \"olts\": [{\"id\": 1, \"name\": \"OLT-1\", \"ip\": \"192.168.1.100\", \"telnet_port\": 23, \"snmp_port\": 161}]}"
            }
          ]
        }
      ]
    },
    {
      "name": "ONU - Read",
      "description": "Read-only endpoints to query ONU information and status",
      "item": [
        {
          "name": "Get Unconfigured ONUs",
          "description": "List all unconfigured ONUs across all OLTs. Optionally filter by serial number or ONU type.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Token", "value": "{{api_key}}", "type": "text" }
            ],
            "url": {
              "raw": "https://{{subdomain}}.smartolt.com/api/onu/unconfigured_onus",
              "protocol": "https",
              "host": ["{{subdomain}}.smartolt.com"],
              "path": ["api", "onu", "unconfigured_onus"],
              "query": [
                { "key": "sn", "value": "", "description": "Filter by serial number (contains search)", "disabled": true },
                { "key": "snonu_type", "value": "", "description": "Filter by ONU type (e.g., Huawei, Nokia, ZTE)", "disabled": true }
              ]
            },
            "description": "Returns unprovisioned ONUs. Use sparingly due to rate limits."
          }
        },
        {
          "name": "Get Unconfigured ONUs for OLT",
          "description": "List unconfigured ONUs for a specific OLT by its ID.",
