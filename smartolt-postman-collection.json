    {
      "name": "ONU - Actions",
      "description": "Write endpoints to provision, configure, and manage ONUs",
      "item": [
        {
          "name": "Authorize ONU",
          "description": "Provision a new ONU (authorize it on the OLT). This is the main endpoint for adding new subscribers.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Token", "value": "{{api_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded", "type": "text" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "olt_id", "value": "1", "description": "OLT ID where ONU will be provisioned" },
                { "key": "pon_type", "value": "gpon", "description": "PON type: gpon or epon" },
                { "key": "sn", "value": "HWTCCXXXXXX", "description": "ONU Serial Number" },
                { "key": "onu_type", "value": "HG8245W5", "description": "ONU model/type" },
                { "key": "onu_mode", "value": "Routing", "description": "ONU mode: Routing or Bridging" },
                { "key": "vlan", "value": "100", "description": "VLAN ID for the ONU" },
                { "key": "zone", "value": "ZONE-1", "description": "Zone/area name" },
                { "key": "name", "value": "Customer Name", "description": "Customer or ONU name" },
                { "key": "board", "value": "", "description": "Board/slot number", "disabled": true },
                { "key": "port", "value": "", "description": "PON port number", "disabled": true },
                { "key": "cvlan", "value": "", "description": "Customer VLAN (for QinQ)", "disabled": true },
                { "key": "svlan", "value": "", "description": "Service VLAN (for QinQ)", "disabled": true },
                { "key": "tag_transform_mode", "value": "", "description": "default, translate, or translate-and-add", "disabled": true },
                { "key": "onu_external_id", "value": "", "description": "Custom external ID for the ONU", "disabled": true },
                { "key": "address_or_comment", "value": "", "description": "Installation address or comment", "disabled": true },
                { "key": "odb", "value": "", "description": "Optical Distribution Box / splitter info", "disabled": true },
                { "key": "upload_speed_profile_name", "value": "", "description": "Upload speed profile name", "disabled": true },
                { "key": "download_speed_profile_name", "value": "", "description": "Download speed profile name", "disabled": true }
              ]
            },
            "url": {
              "raw": "https://{{subdomain}}.smartolt.com/api/onu/authorize_onu",
              "protocol": "https",
              "host": ["{{subdomain}}.smartolt.com"],
              "path": ["api", "onu", "authorize_onu"]
            },
            "description": "Provision a new ONU on the OLT with all required and optional parameters."
          }
        },
