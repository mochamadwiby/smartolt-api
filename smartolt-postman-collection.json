              "protocol": "https",
              "host": ["{{subdomain}}.smartolt.com"],
              "path": ["api", "onu", "unconfigured_onus_for_olt", ":oltId"],
              "variable": [
                { "key": "oltId", "value": "1", "description": "OLT ID (number)" }
              ],
              "query": [
                { "key": "sn", "value": "", "description": "Filter by serial number", "disabled": true },
                { "key": "snonu_type", "value": "", "description": "Filter by ONU type", "disabled": true }
              ]
            },
            "description": "Returns unprovisioned ONUs for a specific OLT."
          }
        },
        {
          "name": "Get All ONUs Details",
          "description": "⚠️ RATE LIMITED: Max 3 calls/hour. Returns full ONU database export. Cache results.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Token", "value": "{{api_key}}", "type": "text" }
            ],
            "url": {
              "raw": "https://{{subdomain}}.smartolt.com/api/onu/get_all_onus_details",
              "protocol": "https",
              "host": ["{{subdomain}}.smartolt.com"],
              "path": ["api", "onu", "get_all_onus_details"],
              "query": [
                { "key": "olt_id", "value": "", "description": "Filter by OLT ID", "disabled": true },
                { "key": "board", "value": "", "description": "Filter by board number", "disabled": true },
                { "key": "port", "value": "", "description": "Filter by port number", "disabled": true },
                { "key": "zone", "value": "", "description": "Filter by zone", "disabled": true }
              ]
            },
            "description": "Full ONU database export. Cache this data — do not poll."
          }
        },
